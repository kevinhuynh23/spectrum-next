    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.31",
